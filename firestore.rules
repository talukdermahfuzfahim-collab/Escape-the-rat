rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    function isValidUserProfile(data) {
      return (!data.keys().contains('uid') || (data.uid is string && data.uid.size() <= 128))
        && (!data.keys().contains('levelProgress') || (data.levelProgress is number && data.levelProgress >= 0))
        && (!data.keys().contains('endlessHighScore') || (data.endlessHighScore is number && data.endlessHighScore >= 0))
        && (!data.keys().contains('displayName') || (data.displayName == null || (data.displayName is string && data.displayName.size() <= 200)))
        && (!data.keys().contains('photoURL') || (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2000)))
        && (!data.keys().contains('dailyCompleted') || data.dailyCompleted is list)
        && (!data.keys().contains('settings') || (
             data.settings is map 
             && (data.settings.get('volume', 0.5) is number)
             && data.settings.get('animations', true) is bool
             && data.settings.get('musicEnabled', true) is bool
           ))
        && (!data.keys().contains('currentSession') || (
             data.currentSession == null || (
               data.currentSession is map
               && data.currentSession.mode is string
               && (data.currentSession.level is number)
               && (data.currentSession.score is number)
               && (data.currentSession.timeLeft is number)
               && data.currentSession.get('updatedAt', '') is string
             )
           ));
    }

    function isValidLeaderboardEntry(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.score is number && data.score >= 0
        && (!data.keys().contains('displayName') || (data.displayName == null || (data.displayName is string && data.displayName.size() <= 200)))
        && data.updatedAt == request.time;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if true; 
      allow list: if false; 
      
      allow create: if isOwner(userId) 
        && isValidUserProfile(incoming())
        && (incoming().get('uid', userId) == userId)
        && (incoming().createdAt == request.time)
        && (incoming().updatedAt == request.time);
      
      allow update: if isOwner(userId)
        && isValidUserProfile(incoming())
        && (incoming().get('uid', userId) == userId)
        && (incoming().createdAt == existing().createdAt)
        && (incoming().updatedAt == request.time);
    }

    match /leaderboards/endless/scores/{scoreId} {
      allow read: if true;
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidLeaderboardEntry(incoming()) 
        && incoming().uid == request.auth.uid
        && isValidId(scoreId);
      
      allow update: if isSignedIn() && incoming().uid == request.auth.uid
        && isValidLeaderboardEntry(incoming())
        && incoming().score > existing().score
        && incoming().diff(existing()).affectedKeys().hasOnly(['score', 'displayName', 'updatedAt']);
    }

    match /leaderboards/levels/scores/{scoreId} {
      allow read: if true;
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidLeaderboardEntry(incoming()) 
        && incoming().uid == request.auth.uid
        && isValidId(scoreId);
      
      allow update: if isSignedIn() && incoming().uid == request.auth.uid
        && isValidLeaderboardEntry(incoming())
        && incoming().score > existing().score
        && incoming().diff(existing()).affectedKeys().hasOnly(['score', 'displayName', 'updatedAt']);
    }
  }
}
